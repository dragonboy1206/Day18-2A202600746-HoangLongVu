# Sao chép tệp này thành .env rồi điền khóa API thật.
# MiMo dùng giao thức tương thích OpenAI Chat Completions.
MIMO_API_KEY=
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2.5-pro
MIMO_THINKING=disabled
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2

# Số yêu cầu làm giàu chạy đồng thời. Nếu gặp lỗi 429, giảm xuống 2 hoặc 1.
ENRICH_MAX_WORKERS=4
RAGAS_MAX_WORKERS=4
RAGAS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Đặt thành 1 khi muốn chạy test mà không gọi API.
DISABLE_LLM=0

# Tương thích với các thư viện chỉ đọc biến OPENAI_API_KEY.
# Có thể để trống nếu đã điền MIMO_API_KEY.
OPENAI_API_KEY=
